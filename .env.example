# ─── Supabase ────────────────────────────────────────────────────────────────
# Copiez ce fichier en .env et remplissez vos valeurs.
# Ne commitez JAMAIS le fichier .env — il est dans .gitignore.
#
# Pour Cloudflare Pages : définissez ces variables dans
# Dashboard → Settings → Environment Variables

# URL de votre instance Supabase (self-hosted ou supabase.com)
VITE_SUPABASE_URL=

# Clé publique anonyme (anon key)
VITE_SUPABASE_ANON_KEY=

# ID du projet Supabase (ex: "default" pour self-hosted)
VITE_SUPABASE_PROJECT_ID=
